# Ignore dependencies (node_modules should be installed inside the container)
node_modules/

# Ignore build outputs
dist/
out/
.tmp/
.cache/
coverage/

# Ignore environment and config files (sensitive data)
.env
.env.*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore version control and local development files
.git/
.gitignore
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Ignore Docker-related files to prevent unnecessary copying
Dockerfile
.dockerignore
docker-compose.yml
docker-compose.override.yml
